<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow effect -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#40000000"
                android:endColor="@android:color/transparent"
                android:type="linear" />
        </shape>
    </item>
    
    <!-- Main background -->
    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/nav_gradient_start"
                android:endColor="@color/nav_gradient_end"
                android:type="linear" />
        </shape>
    </item>
</layer-list>