<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_usage_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="App Usage (24h)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:padding="12dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/aesthetic_text_box"
        android:gravity="center"
        android:textColor="#E0E0E0"
        android:elevation="2dp"/>

    <LinearLayout
        android:id="@+id/permission_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To show your real app usage data, this app needs Usage Access permission.\n\n✓ This allows tracking your actual phone usage\n✓ See which apps you use most\n✓ Get accurate screen time reports\n✓ Your data stays private on your device\n\nTap 'Grant Permission' and find 'BuzzBreakPhone' in the list."
            android:paddingBottom="16dp"
            android:padding="14dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/aesthetic_text_box"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:lineSpacingExtra="3dp"
            android:elevation="2dp"/>
        <Button
            android:id="@+id/btn_grant_usage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Grant Permission"
            android:textSize="13sp"
            android:padding="14dp"
            android:layout_marginHorizontal="4dp"
            android:layout_marginTop="8dp"
            android:elevation="2dp"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:paddingHorizontal="12dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/aesthetic_text_box"
        android:elevation="1dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Name"
            android:textStyle="bold"
            android:textSize="12sp"
            android:textColor="#E0E0E0"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Screen Time"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="end"
            android:textColor="#E0E0E0"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Frequency"
            android:textStyle="bold"
            android:textSize="12sp"
            android:gravity="end"
            android:textColor="#E0E0E0"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_usage"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"/>

</LinearLayout>


