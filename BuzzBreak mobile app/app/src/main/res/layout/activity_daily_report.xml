<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:fadeScrollbars="false"
    android:background="@color/background_light"
    android:id="@+id/main">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:paddingTop="40dp"
    android:gravity="center_horizontal"
    android:layout_gravity="center">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="8dp"
        android:maxWidth="400dp"
        android:gravity="center_horizontal">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_report_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Usage Report"
        android:textStyle="bold"
        android:textSize="14sp"
        android:paddingVertical="12dp"
        android:paddingHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/light_aesthetic_box"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:elevation="3dp"
        android:layout_gravity="center_horizontal"/>

    <!-- Category percentage list -->
    <LinearLayout
        android:id="@+id/category_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/light_aesthetic_box"
        android:padding="8dp"
        android:elevation="2dp">
        
        <!-- Social Media -->
        <LinearLayout
            android:id="@+id/category_social"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/rounded_category_social"
            android:layout_marginBottom="4dp"
            android:elevation="1dp">
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/accent_green"
                android:layout_marginEnd="6dp"
                android:layout_gravity="center_vertical"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Social Media"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/tv_social_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="9sp"/>
        </LinearLayout>
        
        <!-- Games -->
        <LinearLayout
            android:id="@+id/category_games"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/rounded_category_games"
            android:layout_marginBottom="4dp"
            android:elevation="1dp">
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/mint_green"
                android:layout_marginEnd="6dp"
                android:layout_gravity="center_vertical"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Games"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/tv_games_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="9sp"/>
        </LinearLayout>
        
        <!-- Productivity -->
        <LinearLayout
            android:id="@+id/category_productivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/rounded_category_productivity"
            android:layout_marginBottom="4dp"
            android:elevation="1dp">
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/light_green"
                android:layout_marginEnd="6dp"
                android:layout_gravity="center_vertical"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Productivity"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/tv_productivity_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="9sp"/>
        </LinearLayout>
        
        <!-- Others -->
        <LinearLayout
            android:id="@+id/category_others"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="6dp"
            android:background="@drawable/rounded_category_others"
            android:elevation="1dp">
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/soft_green"
                android:layout_marginEnd="6dp"
                android:layout_gravity="center_vertical"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Others"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="10sp"/>
            <TextView
                android:id="@+id/tv_others_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="9sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bar Chart -->
    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/bar_chart"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginVertical="12dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/light_aesthetic_box"
        android:elevation="3dp"
        android:padding="8dp" />

    <!-- Total Screen Time Box -->
    <TextView
        android:id="@+id/tv_screen_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:layout_marginHorizontal="12dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="@drawable/light_aesthetic_box"
        android:textColor="@color/text_primary"
        android:elevation="2dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"/>
    
    <!-- Report Status Box -->
    <TextView
        android:id="@+id/tv_report_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="6dp"
        android:layout_marginHorizontal="12dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="@drawable/light_aesthetic_box"
        android:textColor="@color/text_primary"
        android:elevation="2dp"
        android:gravity="center"
        android:lineSpacingExtra="2dp"/>
    
    <!-- Additional Details Box -->
    <TextView
        android:id="@+id/tv_additional_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:textSize="10sp"
        android:padding="10dp"
        android:background="@drawable/light_aesthetic_box"
        android:textColor="@color/text_secondary"
        android:elevation="1dp"
        android:gravity="center"
        android:lineSpacingExtra="1dp"
        android:visibility="gone"/>
        
    <!-- RecyclerView for app usage list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_daily_report"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/light_aesthetic_box"
        android:elevation="2dp"
        android:padding="8dp"/>

    </LinearLayout>

</LinearLayout>

</ScrollView>