<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.BuzzBreakPhone" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <item name="colorPrimary">@color/nav_accent</item>
        <item name="colorOnPrimary">@color/nav_text_primary</item>
        <item name="colorSurface">@color/nav_surface</item>
        <item name="colorOnSurface">@color/nav_text_primary</item>
        
        <!-- Modern Status Bar -->
        <item name="android:statusBarColor">@color/nav_primary_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/nav_primary_dark</item>
    </style>

    <style name="Theme.BuzzBreakPhone" parent="Base.Theme.BuzzBreakPhone" />
    
    <!-- Modern Navigation Toolbar Style -->
    <style name="ModernToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">@drawable/modern_nav_bg</item>
        <item name="android:elevation">8dp</item>
        <item name="titleTextColor">@color/nav_text_primary</item>
        <item name="android:titleTextAppearance">@style/ModernToolbarTitle</item>
        <item name="navigationIconTint">@color/nav_text_primary</item>
        <item name="android:theme">@style/ModernToolbarTheme</item>
    </style>
    
    <!-- Modern Toolbar Title Text Style -->
    <style name="ModernToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/nav_text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <!-- Modern Toolbar Theme for Navigation Icon -->
    <style name="ModernToolbarTheme">
        <item name="colorControlNormal">@color/nav_text_primary</item>
        <item name="android:selectableItemBackgroundBorderless">@drawable/modern_nav_ripple</item>
    </style>
    
    <!-- Modern Navigation Button Style -->
    <style name="ModernNavButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/nav_text_primary</item>
        <item name="android:background">@drawable/modern_nav_ripple</item>
        <item name="android:padding">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
</resources>